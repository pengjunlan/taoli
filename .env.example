ARBI_MYSQL_HOST=127.0.0.1
ARBI_MYSQL_PORT=3306
ARBI_MYSQL_USER=root
ARBI_MYSQL_PASSWORD=
ARBI_MYSQL_DATABASE=arbitrage_system
ARBI_MYSQL_CHARSET=utf8mb4
ARBI_MYSQL_POOL_NAME=arbitrage_system_pool
ARBI_MYSQL_POOL_SIZE=10
ARBI_MYSQL_CONNECTION_TIMEOUT=5

ARBI_REDIS_HOST=127.0.0.1
ARBI_REDIS_PORT=6379
ARBI_REDIS_PASSWORD=
ARBI_REDIS_DB=0
ARBI_REDIS_SERVER_PATH=
ARBI_REDIS_ENABLED=true
ARBI_REDIS_KEY_PREFIX=arbitrage_system:auth:session:
ARBI_REDIS_SOCKET_TIMEOUT=2

ARBI_SESSION_COOKIE_NAME=arbi_session
ARBI_SESSION_TTL_SECONDS=43200
ARBI_REMEMBER_ME_TTL_SECONDS=2592000
ARBI_PBKDF2_ITERATIONS=200000
ARBI_MIN_USERNAME_LENGTH=4
ARBI_MAX_USERNAME_LENGTH=32
ARBI_MIN_PASSWORD_LENGTH=8
ARBI_SECURE_COOKIE=false
ARBI_SAME_SITE=lax
